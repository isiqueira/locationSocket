# MongoDB
# Connection string for MongoDB database
MONGO_DATABASE=mongodb://localhost:27017/locationdb

# Redis
# Redis connection settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=

# JWT
# Secret key for JWT token generation/verification
JWT_SECRET=changeme

# Server
# Port where the API server will run
PORT=4000

# Cities Data (Optional)
# Base URL for GeoJSON files used for city synchronization
# Local files in src/citiesData/geojson/ take priority
# Only needed if local files are removed
CITIES_DATA_FROM_IBGE=https://raw.githubusercontent.com/tbrugz/geodata-br/master/geojson
